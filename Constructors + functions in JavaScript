function Student(name, surname, gardes){
this.name = name,
this.surname = surname,
this.gardes = gardes
 this.calculateAverage = function() {
        if (this.grades.length === 0) return 0; // перевірка на порожній масив
        
        let sum = 0; //для обчислення 
        for (let i = 0; i < this.grades.length; i++) {
            sum = sum + this.grades[i]; 
        }
        return sum / this.grades.length;
    }
}


function WeekDay(number_day, uaname, enname){
this.number_day = number_day,
this.uaname = uaname,
this.enname = enname,
this.isWeekend = function(){
    if(number_day === 6){
        return true;
    }else if(number_day === 7){
        return true;
    }else{
        return false;
    }
}
}
